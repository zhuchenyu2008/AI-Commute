# Local database
# For local SQLite, keep a relative file URL. Docker Compose overrides this to /app/data/commute.db.
DATABASE_URL=file:./data/commute.db

# Default commute context
DEFAULT_CITY=宁波
DEFAULT_TIMEZONE=Asia/Shanghai

# AMap Web Service
# Leave empty to use the built-in mock AMap client.
AMAP_API_KEY=

# OpenAI-compatible planning model
# Leave OPENAI_API_KEY empty to use the built-in fallback planner.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Local seed account
SEED_USER_EMAIL=user@example.com
SEED_USER_PASSWORD=password

# Scheduler tick API
# Empty disables scheduler tick API auth for local use.
SCHEDULER_TICK_SECRET=

# Telegram notifications
# Recipients are saved per user in the Settings page, not in .env.
TELEGRAM_BOT_TOKEN=

# Email notifications
# Recipients are saved per user in the Settings page, not in .env.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS_USE_SYSTEM_CA=false

# Optional test/server overrides
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
E2E_PORT=3100
